# Flutter / Dart
.dart_tool/
.packages
build/
.flutter-plugins
.flutter-plugins-dependencies
# NOTE: .metadata is intentionally NOT ignored — Flutter uses it to track
# project state for upgrades and it must be committed.

# Windows build ephemeral
windows/flutter/ephemeral/

# JetBrains IDE files generated by `flutter create`
*.iml
.idea/

# Bundled engine (fetched at build time, not committed)
assets/singbox/*.exe
assets/singbox/*.dll

# Secrets / local (never commit)
.env
.env.*
*.local
secrets/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
